# Arthika — Environment Variables Reference
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ======================
# SERVER
# ======================
PORT=5000
NODE_ENV=development

# ======================
# DATABASE (MongoDB Atlas)
# Get from: https://cloud.mongodb.com → Clusters → Connect → Drivers
# ======================
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/arthika

# ======================
# AUTHENTICATION
# Must be a long random secret string (min 32 chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ======================
JWT_SECRET=your_super_secret_jwt_key_here

# ======================
# CLOUDINARY (Receipt Image Storage)
# Get from: https://cloudinary.com/console → Dashboard
# ======================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ======================
# REDIS (Optional — caching for balance/settlement queries)
# Leave empty to use the no-op stub (safe for development)
# For production: use Redis Cloud (https://redis.com/redis-enterprise-cloud/)
# ======================
REDIS_URL=

# ======================
# CORS (Production only)
# Set to your deployed frontend URL to restrict cross-origin requests
# ======================
CLIENT_URL=http://localhost:5173
